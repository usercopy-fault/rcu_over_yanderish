#!/usr/bin/env bash
set -euo pipefail

HUB_ROOT="${FLEET_SYNC_HUB_ROOT:-$HOME/termux-phone_sync}"
DEVICES_DIR="$HUB_ROOT/devices"
REPOS_DIR="$HUB_ROOT/repos"

usage() {
  cat <<'EOF'
Usage:
  fleet-git init <device-name> [remote-url]
  fleet-git status <device-name>
  fleet-git add <device-name>
  fleet-git commit <device-name> "<message>"
  fleet-git push <device-name>
  fleet-git sync <device-name> "<message>"
EOF
}

die() {
  echo "fleet-git: $*" >&2
  exit 1
}

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "missing required command: $1"
}

valid_device_name() {
  case "${1:-}" in
    *[!A-Za-z0-9._-]*|'') return 1 ;;
    *) return 0 ;;
  esac
}

sync_ignore_args() {
  cat <<'EOF'
--exclude=.git/
--exclude=.ssh/authorized_keys
--exclude=.ssh/id_*
--exclude=.ssh/*.pem
--exclude=.ssh/known_hosts
--exclude=.ssh/known_hosts.old
--exclude=.ssh/cm/
--exclude=.cache/
--exclude=.tmp/
--exclude=tmp/
--exclude=*.log
--exclude=*.tmp
--exclude=*.swp
--exclude=*~
--exclude=widget.log
--exclude=__pycache__/
EOF
}

device_paths() {
  DEVICE_NAME="$1"
  valid_device_name "$DEVICE_NAME" || die "invalid device name: $DEVICE_NAME"
  SRC_DIR="$DEVICES_DIR/$DEVICE_NAME/current"
  REPO_DIR="$REPOS_DIR/$DEVICE_NAME"
  [ -d "$SRC_DIR" ] || die "device current directory not found: $SRC_DIR"
}

write_gitignore() {
  cat >"$REPO_DIR/.gitignore" <<'EOF'
.ssh/authorized_keys
.ssh/id_*
.ssh/*.pem
.ssh/known_hosts
.ssh/known_hosts.old
.ssh/cm/
.cache/
.tmp/
tmp/
*.log
*.tmp
*.swp
*~
widget.log
__pycache__/
EOF
}

sync_worktree() {
  mkdir -p "$REPO_DIR"
  mapfile -t ignore_args < <(sync_ignore_args)
  rsync -a --delete "${ignore_args[@]}" "$SRC_DIR/" "$REPO_DIR/"
  write_gitignore
}

ensure_repo_initialized() {
  if [ ! -d "$REPO_DIR/.git" ]; then
    git -C "$REPO_DIR" init
    git -C "$REPO_DIR" branch -M main
  fi
}

ensure_remote() {
  local remote_url="$1"
  [ -n "$remote_url" ] || return 0
  if git -C "$REPO_DIR" remote get-url origin >/dev/null 2>&1; then
    git -C "$REPO_DIR" remote set-url origin "$remote_url"
  else
    git -C "$REPO_DIR" remote add origin "$remote_url"
  fi
}

init_repo() {
  local device_name="$1"
  local remote_url="${2:-}"
  device_paths "$device_name"
  sync_worktree
  ensure_repo_initialized
  ensure_remote "$remote_url"
  git -C "$REPO_DIR" add .gitignore .
  git -C "$REPO_DIR" commit -m "Initial import for $device_name" >/dev/null 2>&1 || true
  echo "$REPO_DIR"
}

status_repo() {
  local device_name="$1"
  device_paths "$device_name"
  sync_worktree
  ensure_repo_initialized
  git -C "$REPO_DIR" status --short --branch
}

add_repo() {
  local device_name="$1"
  device_paths "$device_name"
  sync_worktree
  ensure_repo_initialized
  git -C "$REPO_DIR" add .
  git -C "$REPO_DIR" status --short
}

commit_repo() {
  local device_name="$1"
  local message="$2"
  device_paths "$device_name"
  sync_worktree
  ensure_repo_initialized
  git -C "$REPO_DIR" add .
  git -C "$REPO_DIR" commit -m "$message"
}

push_repo() {
  local device_name="$1"
  device_paths "$device_name"
  ensure_repo_initialized
  git -C "$REPO_DIR" push -u origin main
}

sync_repo() {
  local device_name="$1"
  local message="$2"
  device_paths "$device_name"
  sync_worktree
  ensure_repo_initialized
  git -C "$REPO_DIR" add .
  git -C "$REPO_DIR" commit -m "$message" >/dev/null 2>&1 || true
  git -C "$REPO_DIR" push -u origin main
}

require_cmd git
require_cmd rsync

case "${1:-}" in
  init)
    [ "$#" -ge 2 ] || { usage; exit 1; }
    shift
    init_repo "$@"
    ;;
  status)
    [ "$#" -eq 2 ] || { usage; exit 1; }
    status_repo "$2"
    ;;
  add)
    [ "$#" -eq 2 ] || { usage; exit 1; }
    add_repo "$2"
    ;;
  commit)
    [ "$#" -eq 3 ] || { usage; exit 1; }
    commit_repo "$2" "$3"
    ;;
  push)
    [ "$#" -eq 2 ] || { usage; exit 1; }
    push_repo "$2"
    ;;
  sync)
    [ "$#" -eq 3 ] || { usage; exit 1; }
    sync_repo "$2" "$3"
    ;;
  *)
    usage
    exit 1
    ;;
esac
