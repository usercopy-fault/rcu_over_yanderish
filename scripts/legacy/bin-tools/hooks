# ── Sync ─────────────────────────────────────────

cmd_sync() {
  local target="${1:-all}"
  local FILES="$C2_HOME/hookserver.py $C2_HOME/beacon.py $C2_HOME/nodes.json $C2_HOME/config.json"
  local HOOK_FILES="$C2_HOME/hooks.d/"*

  _sync_node() {
    local node="$1"
    local ssh_host=$(python3 -c "import json; print(json.load(open('$NODES_FILE'))['nodes']['$node']['ssh'])" 2>/dev/null)
    local port=$(python3 -c "import json; print(json.load(open('$NODES_FILE'))['nodes']['$node'].get('port',22))" 2>/dev/null)
    local user=$(python3 -c "import json; print(json.load(open('$NODES_FILE'))['nodes']['$node']['user'])" 2>/dev/null)

    echo -e "  ${CYN}→ $node${RST} ($ssh_host)"

    # Try SSH sync
    if _node_ssh "$node" "echo ok" >/dev/null 2>&1; then
      # Ensure dirs exist
      _node_ssh "$node" "mkdir -p ~/c2/hooks.d ~/c2/logs ~/bin"

      local scp_port=""
      [ "$port" != "22" ] && scp_port="-P $port"

      scp $scp_port $FILES "$ssh_host:~/c2/" 2>/dev/null
      scp $scp_port $HOOK_FILES "$ssh_host:~/c2/hooks.d/" 2>/dev/null
      scp $scp_port "$HOME/bin/hooks" "$ssh_host:~/bin/hooks" 2>/dev/null
      _node_ssh "$node" "chmod +x ~/bin/hooks ~/c2/hooks.d/*.sh 2>/dev/null"

      # Restart hookserver on remote
      _node_ssh "$node" "pkill -f hookserver.py 2>/dev/null; sleep 1; cd ~/c2 && nohup python3 hookserver.py >> logs/server.log 2>&1 &" 2>/dev/null
      echo -e "    ${GRN}Synced + restarted${RST}"
    else
      # Phone fallback: try ADB
      if [ "$node" = "phone" ] && adb devices 2>/dev/null | grep -q "device$"; then
        echo -e "    ${YLW}SSH failed, using ADB...${RST}"
        adb push "$C2_HOME/hookserver.py" /sdcard/c2/hookserver.py 2>/dev/null
        adb push "$C2_HOME/nodes.json" /sdcard/c2/nodes.json 2>/dev/null
        adb push "$HOME/bin/hooks" /sdcard/c2/hooks 2>/dev/null
        for f in $HOOK_FILES; do
          adb push "$f" "/sdcard/c2/hooks.d/$(basename "$f")" 2>/dev/null
        done
        echo -e "    ${GRN}Pushed via ADB.${RST} In Termux: cp -r /sdcard/c2/* ~/c2/ && cp /sdcard/c2/hooks ~/bin/"
      else
        echo -e "    ${RED}Unreachable${RST}"
      fi
    fi
  }

  echo -e "${BLD}Syncing C2 mesh...${RST}"
  if [ "$target" = "all" ]; then
    python3 -c "
import json
nodes = json.load(open('$NODES_FILE'))['nodes']
for name in nodes:
    if name != 'laptop':
        print(name)
" 2>/dev/null | while read -r node; do
      _sync_node "$node"
    done
  else
    _sync_node "$target"
  fi
  echo -e "${GRN}Sync complete${RST}"
}

