    count=$(wc -l < "$d" 2>/dev/null || echo 0)
    echo "" >> "$report"
    echo "### $target ($count findings)" >> "$report"
    echo '```' >> "$report"
    cat "$d" >> "$report"
    echo '```' >> "$report"
