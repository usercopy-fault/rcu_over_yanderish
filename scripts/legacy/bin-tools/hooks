  echo -e "${CYN}Generating report for program: ${WHT}$program${RST}"

  cat > "$report" << HEADER
# Bug Bounty Report — $program
**Generated:** $(date -u '+%Y-%m-%d %H:%M UTC')
**Host:** $(hostname)

## Targets
HEADER

  curl -s "http://127.0.0.1:9800/targets?program=$program" | python3 -c "
import sys,json
for t in json.load(sys.stdin):
    print(f\"- **{t['domain']}** — scope: {t['scope']}, status: {t['status']}\")
    print(f\"  Notes: {t.get('notes','—')}\")
" >> "$report" 2>/dev/null

  echo "" >> "$report"
