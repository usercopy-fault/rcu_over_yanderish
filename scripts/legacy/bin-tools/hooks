# ── Ollama Routing ───────────────────────────────
cmd_ollama() {
  local prompt="${*:?Usage: hooks ollama <prompt>}"

  # If tower tunnel needed, ensure it's up
  if ! ss -tlnp 2>/dev/null | grep -q ":21434 "; then
    ssh -fN -o ConnectTimeout=3 tower 2>/dev/null &
  fi

  python3 -c "
import json, urllib.request, sys

nodes_cfg = json.load(open('$NODES_FILE'))
nodes = nodes_cfg['nodes']
priority = nodes_cfg.get('ollama_priority', [])
prompt = sys.argv[1]

def try_ollama(host, port, model, timeout=30):
    url = f'http://{host}:{port}/api/generate'
    data = json.dumps({'model': model, 'prompt': prompt, 'stream': False}).encode()
    req = urllib.request.Request(url, data=data, headers={'Content-Type': 'application/json'})
    with urllib.request.urlopen(req, timeout=timeout) as resp:
        return json.loads(resp.read())

for node_name in priority:
    node = nodes.get(node_name, {})
    oll = node.get('ollama')
    if not oll:
        continue
    hosts = [oll['host']]
    if oll.get('host_ts'):
        hosts.append(oll['host_ts'])
    port = oll['port']
    models = oll.get('models', [])
    if not models:
        continue
    model = models[0]
    for host in hosts:
        try:
            result = try_ollama(host, port, model)
            print(f'\033[2m[{node_name}:{model}]\033[0m')
            print(result.get('response', ''))
            sys.exit(0)
        except Exception:
            continue

print('\033[0;31mNo Ollama endpoint reachable\033[0m')
sys.exit(1)
" "$prompt"
}

