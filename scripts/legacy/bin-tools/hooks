}

cmd_list() {
  echo -e "${BLD}Installed Hooks${RST} ($C2_HOME/hooks.d/)"
  echo ""
  for f in "$C2_HOME/hooks.d/"*; do
    [ -f "$f" ] || continue
    name=$(basename "$f")
    if [ -x "$f" ]; then
      echo -e "  ${GRN}●${RST} $name"
    else
      echo -e "  ${RED}○${RST} $name ${DIM}(disabled)${RST}"
    fi
  done
}

cmd_add() {
  local name="${1:?Usage: hooks add <event_type_name>}"
  local file="$C2_HOME/hooks.d/${name}.sh"
  cat > "$file" << 'TEMPLATE'
#!/bin/bash
# Hook: DESCRIPTION
# Triggered on: EVENT_TYPE
# Available env: $C2_EVENT, $C2_DATA, $C2_TIMESTAMP, $C2_HOME

echo "Hook triggered: $C2_EVENT" >> "$C2_HOME/logs/hook_debug.log"

# Your logic here:

TEMPLATE
  chmod +x "$file"
  echo -e "${GRN}Created${RST}: $file"
  ${EDITOR:-nano} "$file"
}

cmd_edit() {
  local name="$1"
  local file=$(find "$C2_HOME/hooks.d/" -name "*${name}*" | head -1)
  [ -z "$file" ] && { echo "Hook not found: $name"; return 1; }
  ${EDITOR:-nano} "$file"
}

cmd_disable() {
  local name="$1"
  local file=$(find "$C2_HOME/hooks.d/" -name "*${name}*" | head -1)
  [ -z "$file" ] && { echo "Hook not found: $name"; return 1; }
  chmod -x "$file"
  echo -e "${YLW}Disabled${RST}: $(basename "$file")"
}

cmd_enable() {
  local name="$1"
  local file=$(find "$C2_HOME/hooks.d/" -name "*${name}*" | head -1)
  [ -z "$file" ] && { echo "Hook not found: $name"; return 1; }
  chmod +x "$file"
  echo -e "${GRN}Enabled${RST}: $(basename "$file")"
}

cmd_log() {
  tail -f "$C2_HOME/hookserver.log" "$C2_HOME/logs/all_events.log" 2>/dev/null
}

cmd_dashboard() {
  PORT=$(python3 -c "import json; print(json.load(open('$C2_HOME/config.json')).get('hook_port',9800))" 2>/dev/null || echo "9800")
  URL="http://127.0.0.1:${PORT}/dashboard"
  echo -e "Dashboard: ${WHT}${URL}${RST}"
  if command -v xdg-open &>/dev/null; then
    xdg-open "$URL" 2>/dev/null &
  elif command -v termux-open-url &>/dev/null; then
    termux-open-url "$URL"
  fi
}

# ── Bug Bounty ───────────────────────────────────
RECON_DIR="$C2_HOME/recon"
mkdir -p "$RECON_DIR" 2>/dev/null

bb_add() {
  local domain="${1:?Usage: hooks bb add <domain> [program]}"
  local program="${2:-default}"
  curl -s -X POST "http://127.0.0.1:9800/targets/add" \
    -H "Content-Type: application/json" \
    -d "{\"domain\":\"$domain\",\"program\":\"$program\"}" | python3 -m json.tool 2>/dev/null
}

bb_list() {
  local program="$1"
  local url="http://127.0.0.1:9800/targets"
  [ -n "$program" ] && url="${url}?program=$program"
  echo -e "${BLD}Targets${RST}"
  echo ""
  curl -s "$url" | python3 -c "
import sys,json
targets=json.load(sys.stdin)
colors={'new':'\033[0;36m','recon':'\033[0;33m','testing':'\033[0;35m','done':'\033[0;32m'}
for t in targets:
    c=colors.get(t['status'],'\033[0m')
    scope='IN' if t['scope']=='in' else '\033[0;31mOUT\033[0m'
    print(f\"  {c}{t['status']:8}\033[0m [{scope}] \033[1m{t['domain']}\033[0m  ({t['program']})  {t.get('notes','')}\")
" 2>/dev/null || echo "Server not running?"
}

bb_scope() {
  local domain="${1:?Usage: hooks bb scope <domain> <in|out>}"
  local scope="${2:?Specify: in or out}"
  curl -s -X POST "http://127.0.0.1:9800/targets/update" \
    -H "Content-Type: application/json" \
    -d "{\"domain\":\"$domain\",\"scope\":\"$scope\"}" | python3 -m json.tool 2>/dev/null
}

bb_subs() {
  local domain="${1:?Usage: hooks bb subs <domain>}"
  local outdir="$RECON_DIR/$domain"
  mkdir -p "$outdir"

  echo -e "${CYN}Running subdomain enumeration on ${WHT}$domain${RST}"
  curl -s -X POST "http://127.0.0.1:9800/targets/update" \
    -H "Content-Type: application/json" \
    -d "{\"domain\":\"$domain\",\"status\":\"recon\"}" >/dev/null 2>&1

  subfinder -d "$domain" -silent -o "$outdir/subs.txt" 2>/dev/null
  SUB_COUNT=0
  [ -f "$outdir/subs.txt" ] && SUB_COUNT=$(wc -l < "$outdir/subs.txt")
  echo -e "${GRN}Found ${WHT}$SUB_COUNT${GRN} subdomains${RST}"

  # Store results
  curl -s -X POST "http://127.0.0.1:9800/recon/store" \
    -H "Content-Type: application/json" \
    -d "{\"tool\":\"subfinder\",\"result_type\":\"subdomains\",\"data\":{\"domain\":\"$domain\",\"count\":$SUB_COUNT}}" >/dev/null 2>&1

  # Fire event for hook chaining
  curl -s -X POST "http://127.0.0.1:9800/recon/complete" \
    -H "Content-Type: application/json" \
    -d "{\"stage\":\"subdomain\",\"target\":\"$domain\",\"count\":$SUB_COUNT}" >/dev/null 2>&1

  echo -e "  Results: $outdir/subs.txt"
}

bb_ports() {
  local target="${1:?Usage: hooks bb ports <domain|ip>}"
  local outdir="$RECON_DIR/$target"
  mkdir -p "$outdir"

  echo -e "${CYN}Running port scan on ${WHT}$target${RST}"

  # Use subs if available, otherwise direct target
  if [ -f "$outdir/subs.txt" ]; then
    echo -e "${DIM}Using subdomain list ($(wc -l < "$outdir/subs.txt" 2>/dev/null || echo 0) hosts)${RST}"
    naabu -list "$outdir/subs.txt" -silent -o "$outdir/ports.txt" 2>/dev/null
  else
    naabu -host "$target" -silent -o "$outdir/ports.txt" 2>/dev/null
  fi

  PORT_COUNT=0
  [ -f "$outdir/ports.txt" ] && PORT_COUNT=$(wc -l < "$outdir/ports.txt")
  echo -e "${GRN}Found ${WHT}$PORT_COUNT${GRN} open ports${RST}"

  curl -s -X POST "http://127.0.0.1:9800/recon/store" \
    -H "Content-Type: application/json" \
    -d "{\"tool\":\"naabu\",\"result_type\":\"ports\",\"data\":{\"target\":\"$target\",\"count\":$PORT_COUNT}}" >/dev/null 2>&1

  curl -s -X POST "http://127.0.0.1:9800/recon/complete" \
    -H "Content-Type: application/json" \
    -d "{\"stage\":\"ports\",\"target\":\"$target\",\"count\":$PORT_COUNT}" >/dev/null 2>&1

  echo -e "  Results: $outdir/ports.txt"
}

bb_httpx() {
  local target="${1:?Usage: hooks bb httpx <domain>}"
  local outdir="$RECON_DIR/$target"
  mkdir -p "$outdir"

  echo -e "${CYN}Running HTTP probe on ${WHT}$target${RST}"

  if [ -f "$outdir/subs.txt" ]; then
    httpx -l "$outdir/subs.txt" -silent -status-code -title -tech-detect -o "$outdir/httpx.txt" 2>/dev/null
  else
    echo "$target" | httpx -silent -status-code -title -tech-detect -o "$outdir/httpx.txt" 2>/dev/null
  fi
  LIVE=0
  [ -f "$outdir/httpx.txt" ] && LIVE=$(wc -l < "$outdir/httpx.txt")
  echo -e "${GRN}Found ${WHT}$LIVE${GRN} live hosts${RST}"

  curl -s -X POST "http://127.0.0.1:9800/recon/store" \
    -H "Content-Type: application/json" \
    -d "{\"tool\":\"httpx\",\"result_type\":\"live_hosts\",\"data\":{\"target\":\"$target\",\"count\":$LIVE}}" >/dev/null 2>&1

  echo -e "  Results: $outdir/httpx.txt"
}

bb_nuclei() {
  local target="${1:?Usage: hooks bb nuclei <domain>}"
  local outdir="$RECON_DIR/$target"
  mkdir -p "$outdir"

  echo -e "${CYN}Running Nuclei scan on ${WHT}$target${RST}"

  local input="$outdir/httpx.txt"
  if [ -f "$input" ]; then
    # Extract just URLs from httpx output
    awk '{print $1}' "$input" > "$outdir/urls.txt"
    nuclei -l "$outdir/urls.txt" -silent -severity medium,high,critical -o "$outdir/nuclei.txt" 2>/dev/null
  else
    nuclei -u "$target" -silent -severity medium,high,critical -o "$outdir/nuclei.txt" 2>/dev/null
  fi

  VULN_COUNT=0
  [ -f "$outdir/nuclei.txt" ] && VULN_COUNT=$(wc -l < "$outdir/nuclei.txt")
  echo -e "${GRN}Found ${WHT}$VULN_COUNT${GRN} vulnerabilities${RST}"

  if [ "${VULN_COUNT:-0}" -gt 0 ] 2>/dev/null; then
    curl -s -X POST "http://127.0.0.1:9800/vuln/found" \
      -H "Content-Type: application/json" \
      -d "{\"target\":\"$target\",\"count\":$VULN_COUNT,\"tool\":\"nuclei\"}" >/dev/null 2>&1
  fi

  echo -e "  Results: $outdir/nuclei.txt"
}

