NODES_FILE="$C2_HOME/nodes.json"

_node_ssh() {
  local node="$1"; shift
  local ssh_host=$(python3 -c "import json; n=json.load(open('$NODES_FILE'))['nodes']['$node']; print(n['ssh'])" 2>/dev/null)
  local ssh_fb=$(python3 -c "import json; n=json.load(open('$NODES_FILE'))['nodes']['$node']; print(n.get('ssh_fallback',''))" 2>/dev/null)
  local port=$(python3 -c "import json; n=json.load(open('$NODES_FILE'))['nodes']['$node']; print(n.get('port',22))" 2>/dev/null)

  if [ "$port" != "22" ]; then
    ssh -o ConnectTimeout=3 -p "$port" "$ssh_host" "$@" 2>/dev/null && return 0
    [ -n "$ssh_fb" ] && ssh -o ConnectTimeout=3 -p "$port" "$ssh_fb" "$@" 2>/dev/null && return 0
  else
    ssh -o ConnectTimeout=3 "$ssh_host" "$@" 2>/dev/null && return 0
    [ -n "$ssh_fb" ] && ssh -o ConnectTimeout=3 "$ssh_fb" "$@" 2>/dev/null && return 0
  fi
  return 1
}

