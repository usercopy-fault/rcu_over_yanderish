cmd_start() {
  if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
    echo -e "${YLW}Hook server already running (PID $(cat "$PIDFILE"))${RST}"
    return
  fi
  echo -e "${CYN}Starting C2 hook server...${RST}"
  nohup python3 "$HOOKSERVER" >> "$C2_HOME/logs/server.log" 2>&1 &
  echo $! > "$PIDFILE"
  sleep 1
  if kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
    echo -e "${GRN}Hook server started (PID $(cat "$PIDFILE"))${RST}"
    echo -e "  Webhook:  http://0.0.0.0:9800"
    echo -e "  Callback: http://0.0.0.0:9801"
    echo -e "  Dashboard: http://0.0.0.0:9800/dashboard"
  else
    echo -e "${RED}Failed to start. Check $C2_HOME/logs/server.log${RST}"
  fi
}

cmd_stop() {
  if [ -f "$PIDFILE" ]; then
    PID=$(cat "$PIDFILE")
    if kill -0 "$PID" 2>/dev/null; then
      kill "$PID" 2>/dev/null
      sleep 1
      kill -9 "$PID" 2>/dev/null
      echo -e "${GRN}Stopped (PID $PID)${RST}"
    fi
    rm -f "$PIDFILE"
  else
    echo -e "${DIM}Not running${RST}"
    pkill -f "hookserver.py" 2>/dev/null
  fi
}

cmd_restart() { cmd_stop; sleep 1; cmd_start; }

cmd_status() {
  echo -e "${BLD}C2 Hook System Status${RST}"
  echo ""
  if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
    echo -e "  Hook Server:    ${GRN}running${RST} (PID $(cat "$PIDFILE"))"
  else
    echo -e "  Hook Server:    ${RED}stopped${RST}"
  fi

  # Check ports
  for port in 9800 9801; do
    if ss -tlnp 2>/dev/null | grep -q ":$port " || netstat -tlnp 2>/dev/null | grep -q ":$port "; then
      echo -e "  Port $port:       ${GRN}listening${RST}"
    else
      echo -e "  Port $port:       ${RED}closed${RST}"
    fi
  done

  if [ -f "$DB" ]; then
    EVENTS=$(sqlite3 "$DB" "SELECT COUNT(*) FROM events" 2>/dev/null || echo "?")
    CBS=$(sqlite3 "$DB" "SELECT COUNT(*) FROM callbacks" 2>/dev/null || echo "?")
    echo -e "  Events logged:  ${WHT}$EVENTS${RST}"
    echo -e "  Callbacks:      ${WHT}$CBS${RST}"
  fi

  # Beacon status
  if pgrep -f "beacon.py serve" >/dev/null 2>&1; then
    echo -e "  Beacon:         ${GRN}listening${RST} (:9802/HTTP + :5353/DNS)"
  elif pgrep -f "beacon.py" >/dev/null 2>&1; then
    echo -e "  Beacon:         ${YLW}heartbeat only${RST}"
  else
    echo -e "  Beacon:         ${DIM}stopped${RST}"
  fi

  echo ""
  echo -e "  ${BLD}C2 Frameworks${RST}"
  pgrep -f "empire.py\|powershell-empire" >/dev/null 2>&1 \
    && echo -e "  Empire:         ${GRN}running${RST}" \
    || echo -e "  Empire:         ${DIM}stopped${RST}"
  pgrep -f "havoc server" >/dev/null 2>&1 \
    && echo -e "  Havoc:          ${GRN}running${RST}" \
    || echo -e "  Havoc:          ${DIM}stopped${RST}"
  pgrep -f "Villain.py" >/dev/null 2>&1 \
    && echo -e "  Villain:        ${GRN}running${RST}" \
    || echo -e "  Villain:        ${DIM}stopped${RST}"
  echo ""
}

cmd_events() {
  if [ ! -f "$DB" ]; then echo "No events yet."; return; fi
  echo -e "${BLD}Recent Events${RST}"
  echo ""
  sqlite3 -header -column "$DB" \
    "SELECT id, substr(timestamp,1,19) as time, source, event_type, substr(data,1,60) as data, src_ip FROM events ORDER BY id DESC LIMIT ${1:-20}"
}

cmd_callbacks() {
  if [ ! -f "$DB" ]; then echo "No callbacks yet."; return; fi
  echo -e "${BLD}OOB Callbacks${RST}"
  echo ""
  sqlite3 -header -column "$DB" \
    "SELECT id, substr(timestamp,1,19) as time, src_ip, method, substr(path,1,40) as path, token FROM callbacks ORDER BY id DESC LIMIT ${1:-20}"
}

cmd_fire() {
  local etype="${1:-test}"
  shift
  local data="${*:-{\"test\":true}}"
  echo -e "${CYN}Firing event: ${etype}${RST}"
  curl -s -X POST "http://127.0.0.1:9800/${etype}" \
    -H "Content-Type: application/json" \
    -d "$data" | python3 -m json.tool 2>/dev/null || echo "Server not running?"
}

cmd_token() {
  TOKEN=$(python3 -c "import hashlib,time,os; print(hashlib.sha256(f'{time.time()}{os.urandom(8).hex()}'.encode()).hexdigest()[:16])")
  PORT=$(python3 -c "import json; print(json.load(open('$C2_HOME/config.json')).get('callback_port',9801))" 2>/dev/null || echo "9801")
  TSIP=$(ip -4 -o addr show tailscale0 2>/dev/null | awk '{print $4}' | cut -d/ -f1)
  [ -z "$TSIP" ] && TSIP="YOUR_IP"

  echo -e "${BLD}Callback Token: ${GRN}${TOKEN}${RST}"
  echo ""
  echo -e "  ${WHT}HTTP:${RST}   http://${TSIP}:${PORT}/${TOKEN}"
  echo -e "  ${WHT}IMG:${RST}    <img src=\"http://${TSIP}:${PORT}/${TOKEN}/x.png\">"
  echo -e "  ${WHT}JS:${RST}     <script src=\"http://${TSIP}:${PORT}/${TOKEN}/x.js\"></script>"
  echo -e "  ${WHT}SVG:${RST}    <img src=\"http://${TSIP}:${PORT}/${TOKEN}/x.svg\">"
  echo -e "  ${WHT}CSS:${RST}    <link href=\"http://${TSIP}:${PORT}/${TOKEN}/x.css\" rel=\"stylesheet\">"
  echo -e "  ${WHT}XML:${RST}    http://${TSIP}:${PORT}/${TOKEN}/x.xml"
  echo -e "  ${WHT}Curl:${RST}   curl http://${TSIP}:${PORT}/${TOKEN}"
  echo ""
}

cmd_url() {
  PORT=$(python3 -c "import json; print(json.load(open('$C2_HOME/config.json')).get('callback_port',9801))" 2>/dev/null || echo "9801")
  HPORT=$(python3 -c "import json; print(json.load(open('$C2_HOME/config.json')).get('hook_port',9800))" 2>/dev/null || echo "9800")
  TSIP=$(ip -4 -o addr show tailscale0 2>/dev/null | awk '{print $4}' | cut -d/ -f1)
  LANIP=$(ip -4 -o addr show wlan0 2>/dev/null | awk '{print $4}' | cut -d/ -f1)
  [ -z "$LANIP" ] && LANIP=$(ip -4 -o addr show eth0 2>/dev/null | awk '{print $4}' | cut -d/ -f1)

  echo -e "${BLD}C2 Hook URLs${RST}"
  echo ""
  echo -e "  ${WHT}Tailscale:${RST}"
  echo -e "    Webhook:   http://${TSIP}:${HPORT}"
  echo -e "    Callback:  http://${TSIP}:${PORT}"
  echo -e "    Dashboard: http://${TSIP}:${HPORT}/dashboard"
  echo ""
  echo -e "  ${WHT}LAN:${RST}"
  echo -e "    Webhook:   http://${LANIP}:${HPORT}"
  echo -e "    Callback:  http://${LANIP}:${PORT}"
  echo -e "    Dashboard: http://${LANIP}:${HPORT}/dashboard"
  echo ""
  echo -e "  ${WHT}Havoc webhook config:${RST}"
  echo -e "    Url = \"http://${TSIP}:${HPORT}/havoc/event\""
  echo ""
}

