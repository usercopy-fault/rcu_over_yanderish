    profile="/usr/share/havoc/profiles/havoc.yaotl"
  fi
  echo -e "${CYN}Starting Havoc teamserver...${RST}"
  if pgrep -f "havoc server" >/dev/null 2>&1; then
    echo -e "${YLW}Already running${RST}"
    return
  fi
  nohup havoc server --profile "$profile" >> "$C2_HOME/logs/havoc.log" 2>&1 &
  echo -e "${GRN}Havoc started.${RST} Port: 40056"
  echo -e "  Client: ${WHT}havoc client${RST}"
