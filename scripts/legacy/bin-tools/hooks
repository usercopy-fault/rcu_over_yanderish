  sqlite3 "$DB" "SELECT timestamp, event_type, data FROM events WHERE source LIKE '%recon%' OR event_type LIKE '%vuln%' ORDER BY id DESC LIMIT 20" 2>/dev/null | while IFS='|' read -r ts etype data; do
